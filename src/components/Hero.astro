---
---

<section id="hero" class="h-dvh bg-[var(--color-bg)] flex flex-col" style="padding-top: 60px;">

  <div class="shrink-0 px-8 md:px-16 xl:px-24 pt-10 pb-8 text-center" style="animation: fadeUp 0.8s ease both;">
    <h1 class="font-display font-extrabold text-[clamp(28px,4.5vw,62px)] text-white leading-[1.08] tracking-[-0.02em] mb-5">
      <span data-fr>Je transforme vos idées en</span>
      <span data-en>I turn your ideas into</span>
      {' '}<span class="text-[var(--color-accent)]">
        <span data-fr>applications web</span>
        <span data-en>web applications</span>
      </span>{' '}
      <span data-fr>qui tiennent dans le temps.</span>
      <span data-en>built to last.</span>
    </h1>
    <p class="text-white/45 text-[12px] font-mono tracking-[1px]">
      <span data-fr>10 ans d'expérience · Sites vitrines · Applications métier · Tout secteur</span>
      <span data-en>10 years experience · Showcase sites · Business apps · Any industry</span>
    </p>
  </div>

  <!-- Split panel — fills all remaining viewport height -->
  <div
    id="hero-split"
    class="flex-1 min-h-0 flex mx-6 md:mx-16 xl:mx-24 mb-4 rounded-[14px] overflow-hidden border border-white/7 relative"
    style="box-shadow: 0 36px 90px rgba(0,0,0,0.75);"
  >
    <!-- LEFT — terminal + editor -->
    <div class="w-[40%] flex-shrink-0 border-r border-white/7 overflow-hidden relative hidden md:flex flex-col">

      <!-- Terminal -->
      <div data-panel="terminal" class="absolute inset-0 flex flex-col transition-opacity duration-[450ms]" style="background:#1e1e2e;">
        <div class="flex items-center gap-1.5 px-3 py-2 border-b border-white/5 shrink-0" style="background:#181825;">
          <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
          <span class="font-mono text-[9px] text-white/30 ml-2">zsh — monsite</span>
        </div>
        <div id="terminal-body" class="flex-1 px-4 py-3.5 font-mono text-[11.5px] leading-[1.9] overflow-y-auto text-[#cdd6f4]">
          <div class="flex items-center">
            <span style="color:#4ade80">quentin</span>
            <span style="color:#94a3b8"> ~/monsite</span>
            <span style="color:#e2e8f0"> $ </span>
            <span id="terminal-cmd"></span>
            <span id="terminal-cursor" class="inline-block w-1.5 h-3 bg-[#cdd6f4] ml-px align-middle" style="animation: blink 1s step-end infinite;"></span>
          </div>
          <div id="terminal-result"></div>
        </div>
      </div>

      <!-- Editor (Sublime / VS Code style) -->
      <div data-panel="editor" class="absolute inset-0 flex flex-col transition-opacity duration-[450ms] opacity-0" style="background:#272822;">
        <div class="flex items-center shrink-0 border-b border-black/40" style="background:#1d1d1a;">
          <div class="flex items-center px-4 py-[7px] border-t-2 border-r border-black/30 font-mono text-[10.5px] text-[#f8f8f2] whitespace-nowrap" style="border-top-color: var(--color-accent); background:#272822;">
            <span data-editor-tab>file.blade.php</span>
          </div>
          <span class="ml-auto pr-3.5 font-mono text-[9px] text-white/20" data-editor-lang>Blade</span>
        </div>
        <div class="flex-1 overflow-y-auto py-2" id="editor-code" data-editor-code></div>
        <div class="px-3 py-1 flex justify-between items-center shrink-0 font-mono text-[8.5px] text-white/70" style="background: var(--color-accent-light);">
          <span>◆ main</span>
          <span data-editor-lang>Blade</span>
        </div>
      </div>
    </div>

    <!-- RIGHT — Mac monitor frame -->
    <div class="flex-1 min-w-0 flex flex-col" style="background: #0c0c10; padding: 10px 10px 0 10px;">

      <!-- Screen -->
      <div class="flex-1 flex flex-col overflow-hidden" style="background:#161b22; border-radius: 8px 8px 0 0; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05);">
        <!-- Browser chrome -->
        <div class="flex items-center gap-1.5 px-3 py-2 border-b border-white/6 shrink-0" style="background:#1c2128;">
          <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
          <div class="flex-1 rounded bg-[#0d1117] h-5 ml-2 px-2.5 flex items-center gap-1 overflow-hidden">
            <span id="browser-lock" class="text-[8px] opacity-30 hidden">🔒</span>
            <span id="browser-url" class="font-mono text-[9px] text-white/20 truncate">about:blank</span>
          </div>
        </div>

        <!-- Site preview -->
        <div class="flex-1 relative overflow-hidden">
          <div data-site-preview data-state="empty" class="absolute inset-0 overflow-y-auto"></div>
        </div>
      </div>

      <!-- Monitor chin -->
      <div class="shrink-0" style="background: #1a1a20; height: 20px; border-radius: 0 0 6px 6px; display: flex; align-items: center; justify-content: center; border-top: 1px solid rgba(255,255,255,0.04);">
        <div style="width: 5px; height: 5px; border-radius: 50%; background: #2e2e38;"></div>
      </div>
    </div>

    <!-- Mobile badge (visible only on small screens) -->
    <div class="absolute top-3 right-3 md:hidden flex items-center gap-1.5 bg-[var(--color-accent)]/20 px-2.5 py-1 rounded-full">
      <span class="font-mono text-[9px] text-[var(--color-accent-light)]" style="animation: glowPulse 2s ease-in-out infinite;">✎ live editing…</span>
    </div>

    <!-- CTA overlay -->
    <div
      data-hero-overlay
      class="hidden absolute inset-0 z-20 flex flex-col items-center justify-center gap-4 px-9 text-center"
      style="background: rgba(5,7,14,0.86); backdrop-filter: blur(8px); animation: fadeIn 0.6s ease both;"
    >
      <p class="font-mono text-[9px] tracking-[3px] text-[var(--color-accent-light)] uppercase mb-1">
        <span data-fr>Ce que je fais concrètement</span>
        <span data-en>What I actually do</span>
      </p>
      <h2 class="font-display font-extrabold text-[clamp(19px,3.2vw,30px)] text-white leading-[1.2] max-w-[480px]">
        <span data-fr>C'est ce type de projet<br/><span class="text-[var(--color-accent-light)]">que je réalise pour vous.</span></span>
        <span data-en>This is the kind of project<br/><span class="text-[var(--color-accent-light)]">I build for you.</span></span>
      </h2>
      <p class="text-[12px] text-white/45 max-w-[340px] leading-[1.65]">
        <span data-fr>De la première ligne de code à la mise en ligne — propre, testé, livré dans les délais.</span>
        <span data-en>From the first line of code to deployment — clean, tested, on time.</span>
      </p>
      <a
        href="https://www.linkedin.com/in/quentin-anvo"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[var(--color-accent)] text-white px-7 py-3 rounded-[10px] font-display font-bold text-[15px] no-underline hover:opacity-90 transition-opacity"
        style="box-shadow: 0 6px 28px oklch(55% 0.22 260 / 0.45);"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        <span data-fr>Me contacter sur LinkedIn</span>
        <span data-en>Contact me on LinkedIn</span>
      </a>
      <button
        data-restart-btn
        class="bg-transparent border-0 text-white/20 font-mono text-[9px] cursor-pointer tracking-[1px] mt-1 hover:text-white/50 transition-colors"
      >
        ↺ <span data-fr>rejouer</span><span data-en>replay</span>
      </button>
    </div>
  </div>

  <p class="shrink-0 text-center pb-3 text-white/10 font-mono text-[9px] tracking-[2px]">SCROLL ↓</p>
</section>

<style>
  /* Editor line layout */
  :global(.editor-line) {
    display: flex;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    line-height: 1.8;
    white-space: pre;
  }
  :global(.editor-line--typing) {
    background: rgba(166,226,46,0.05);
  }
  :global(.editor-gutter) {
    width: 30px;
    text-align: right;
    padding-right: 10px;
    color: #3e3d32;
    flex-shrink: 0;
    user-select: none;
    font-size: 9.5px;
  }
  :global(.editor-content) {
    flex: 1;
    padding-left: 4px;
  }

  /* Site preview states */
  [data-site-preview] { font-family: system-ui, sans-serif; }
</style>

<script>
  import { HeroAnimation }  from '../js/hero-animation.js';
  import { pickScenario }   from '../data/scenarios.js';
  import { renderSitePreview } from '../js/site-preview.js';

  const scenario  = pickScenario();
  const root      = document.getElementById('hero-split')!;
  const animation = new HeroAnimation(root);

  // Expose scenario id to About section for the dynamic stat
  document.documentElement.dataset.scenario = scenario.id;

  // Wire up site preview renderer (reacts to data-state changes)
  renderSitePreview(root, scenario.id);

  // Start animation
  animation.run(scenario.id);

  // Replay button
  root.querySelector('[data-restart-btn]')?.addEventListener('click', () => {
    root.querySelector('[data-hero-overlay]')?.classList.add('hidden');
    animation.restart(scenario.id);
  });
</script>
