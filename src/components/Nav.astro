---
---

<nav
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 h-[60px] flex items-center justify-between px-6 md:px-16 xl:px-24 transition-all duration-400"
>
  <a
    href="#"
    class="font-mono font-bold text-[17px] text-white tracking-[-0.5px] no-underline"
    aria-label="Quentin Anvo — retour en haut"
  >
    Q.A<span class="text-[var(--color-accent)]">_</span>
  </a>

  <ul id="nav-links" class="hidden sm:flex gap-7 list-none nav-reveal" role="list">
    <li><a href="#services" class="nav-link"><span data-fr>Services</span><span data-en>Services</span></a></li>
    <li><a href="#projects" class="nav-link"><span data-fr>Projets</span><span data-en>Projects</span></a></li>
    <li><a href="#about"    class="nav-link"><span data-fr>À propos</span><span data-en>About</span></a></li>
  </ul>

  <div class="flex items-center gap-2.5">
    <div id="nav-available" class="hidden sm:flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border nav-reveal nav-available">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
      <span class="font-mono text-[9px] text-green-400"><span data-fr>Disponible</span><span data-en>Available</span></span>
    </div>

    <div id="lang-toggle" class="flex items-center rounded overflow-hidden border border-white/10" role="group" aria-label="Langue">
      <button data-lang-btn="fr" class="lang-btn px-2.5 py-1.5 font-mono text-[11px] cursor-pointer border-r border-white/10 transition-colors">
        🇫🇷 FR
      </button>
      <button data-lang-btn="en" class="lang-btn px-2.5 py-1.5 font-mono text-[11px] cursor-pointer transition-colors">
        🇬🇧 EN
      </button>
    </div>

    <a
      href="https://www.linkedin.com/in/quentin-anvo"
      target="_blank"
      rel="noopener noreferrer"
      class="px-4 py-2 rounded bg-[var(--color-accent)] text-white font-display font-bold text-sm no-underline hover:opacity-90 transition-opacity"
    >
      LinkedIn <span aria-hidden="true">→</span>
    </a>
  </div>
</nav>

<style>
  .nav-link {
    font-size: 14px;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-link:hover { color: #fff; }

  .nav-reveal {
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }
  .nav-reveal.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .nav-available {
    background: rgba(34,197,94,0.08);
    border-color: rgba(34,197,94,0.25);
    animation: glowPulse 2s ease-in-out infinite;
  }

  .lang-btn {
    background: transparent;
    color: rgba(255,255,255,0.4);
    border: none;
  }
  .lang-btn.active {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }
  .lang-btn:hover:not(.active) { color: rgba(255,255,255,0.7); }
</style>

<script>
  const nav        = document.getElementById('nav')!;
  const html       = document.documentElement;
  const revealEls  = nav.querySelectorAll<HTMLElement>('.nav-reveal');

  function setLang(lang: 'fr' | 'en') {
    html.dataset.lang = lang;
    html.lang         = lang;
    localStorage.setItem('lang', lang);
    nav.querySelectorAll<HTMLButtonElement>('[data-lang-btn]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.langBtn === lang);
    });
    document.dispatchEvent(new CustomEvent('langchange', { detail: lang }));
  }

  nav.querySelectorAll<HTMLButtonElement>('[data-lang-btn]').forEach(btn => {
    btn.addEventListener('click', () => setLang(btn.dataset.langBtn!));
  });

  let wasScrolled = false;
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 80;
    if (scrolled === wasScrolled) return;
    wasScrolled = scrolled;
    Object.assign(nav.style, {
      background:     scrolled ? 'rgba(7,9,15,0.92)'                : 'transparent',
      backdropFilter: scrolled ? 'blur(16px)'                       : 'none',
      borderBottom:   scrolled ? '1px solid rgba(255,255,255,0.05)' : 'none',
    });
    revealEls.forEach(el => el.classList.toggle('visible', scrolled));
  }, { passive: true });

  const raw = localStorage.getItem('lang');
  const saved: 'fr' | 'en' = raw === 'en' ? 'en' : 'fr';
  setLang(saved);
</script>
