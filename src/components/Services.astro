---
import { SERVICES } from '../data/services';
---

<section id="services" class="py-14 md:py-28 px-6 md:px-16 xl:px-24" style="background: var(--color-bg);">
  <div class="max-w-[1280px] mx-auto">

    <h2 class="font-mono font-bold tracking-[0.25em] uppercase mb-12" style="color: var(--color-accent); font-size: clamp(11px, 1.1vw, 14px);">
      <span data-fr>Ce que je fais</span><span data-en>What I do</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {SERVICES.map(service => (
        <div
          class="service-card group px-6 md:px-10 py-8 md:py-12 cursor-default transition-all duration-300 rounded-sm"
          style="background: var(--color-surface);"
        >
          <div class="text-[28px] mb-5" style="color: var(--color-accent);">
            {service.icon}
          </div>
          <h3 class="font-display font-bold text-[22px] text-white mb-3 leading-[1.2]">
            <span data-fr>{service.fr.title}</span>
            <span data-en>{service.en.title}</span>
          </h3>
          <p class="text-[14px] leading-[1.7]" style="color: var(--color-muted);">
            <span data-fr>{service.fr.desc}</span>
            <span data-en>{service.en.desc}</span>
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .service-card {
    border-top: 2px solid transparent;
    transition: border-color 0.2s, background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .service-card:hover {
    border-top-color: var(--color-accent);
    background: var(--color-surface-alt) !important;
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
  }
</style>
