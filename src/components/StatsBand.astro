---
---

<div class="py-16 md:py-24 px-6 md:px-16 xl:px-24" style="background: var(--color-bg);">
  <div class="max-w-[1280px] mx-auto">

    <div class="flex items-center gap-4 mb-14 md:mb-20">
      <div class="flex-1 h-px" style="background: rgba(255,255,255,0.06);"></div>
      <span class="font-mono text-[10px] tracking-[3px]" style="color: var(--color-accent);">◆</span>
      <div class="flex-1 h-px" style="background: rgba(255,255,255,0.06);"></div>
    </div>

    <dl class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-6">
      <div>
        <dt class="font-display font-extrabold leading-none mb-3" style="color: var(--color-accent); font-size: clamp(48px, 7vw, 80px);">∞</dt>
        <dd class="font-mono text-[11px] text-white/35 leading-[1.55]">
          <span data-fr>PR mergées sans drama</span>
          <span data-en>drama-free PR merges</span>
        </dd>
      </div>
      <div>
        <dt class="font-display font-extrabold leading-none mb-3" style="color: var(--color-accent); font-size: clamp(48px, 7vw, 80px);">31</dt>
        <dd class="font-mono text-[11px] text-white/35 leading-[1.55]">
          <span data-fr>déploiements réussis un vendredi</span>
          <span data-en>successful Friday deploys</span>
        </dd>
      </div>
      <div>
        <dt class="font-display font-extrabold leading-none mb-3" style="color: var(--color-accent); font-size: clamp(48px, 7vw, 80px);">47</dt>
        <dd class="font-mono text-[11px] text-white/35 leading-[1.55]">
          <span data-fr>migrations sans sueur froide</span>
          <span data-en>painless migrations</span>
        </dd>
      </div>
      <div>
        <dt class="font-display font-extrabold leading-none mb-3" style="color: var(--color-accent); font-size: clamp(48px, 7vw, 80px);">8+</dt>
        <dd class="font-mono text-[11px] text-white/35 leading-[1.55]">
          <span data-fr>secteurs métier différents</span>
          <span data-en>different business domains</span>
        </dd>
      </div>
    </dl>
  </div>
</div>
